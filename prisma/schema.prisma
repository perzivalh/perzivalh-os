generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(cuid())
  name            String
  email           String            @unique
  password_hash   String
  role            UserRole          @default(recepcion)
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now())
  AudienceSegment AudienceSegment[] @relation("AudienceCreatedBy")
  AuditLog        AuditLog[]        @relation("UserAuditLogs")
  Campaign        Campaign[]        @relation("CampaignCreatedBy")
  Conversation    Conversation[]    @relation("AssignedConversations")
  MetaTemplate    MetaTemplate[]    @relation("MetaTemplateCreatedBy")
}

model Conversation {
  id                  String              @id @default(cuid())
  wa_id               String
  phone_e164          String
  display_name        String?
  status              ConversationStatus  @default(open)
  assigned_user_id    String?
  last_message_at     DateTime?
  created_at          DateTime            @default(now())
  partner_id          Int?
  patient_id          Int?
  verification_method VerificationMethod?
  verified_at         DateTime?
  phone_number_id     String?
  primary_tag_id      String?
  CampaignMessage     CampaignMessage[]
  assigned_user       User?               @relation("AssignedConversations", fields: [assigned_user_id], references: [id])
  Tag                 Tag?                @relation(fields: [primary_tag_id], references: [id])
  tags                ConversationTag[]
  messages            Message[]

  @@unique([wa_id, phone_number_id])
  @@index([status])
  @@index([assigned_user_id])
  @@index([last_message_at])
  @@index([partner_id])
  @@index([phone_number_id])
}

model Message {
  id              String           @id @default(cuid())
  conversation_id String
  direction       MessageDirection
  type            MessageType
  text            String?
  raw_json        Json
  created_at      DateTime         @default(now())
  conversation    Conversation     @relation(fields: [conversation_id], references: [id])

  @@index([conversation_id, created_at])
  @@index([conversation_id, created_at(sort: Desc)], map: "message_conversation_id_created_at_desc_idx")
}

model Tag {
  id           String            @id @default(cuid())
  name         String            @unique
  color        String?
  AudienceTag  AudienceTag[]
  Conversation Conversation[]
  tags         ConversationTag[]
}

model ConversationTag {
  conversation_id String
  tag_id          String
  created_at      DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversation_id], references: [id])
  tag             Tag          @relation(fields: [tag_id], references: [id])

  @@id([conversation_id, tag_id])
}

model Settings {
  id                 Int      @id @default(1)
  bot_enabled        Boolean  @default(true)
  auto_reply_enabled Boolean  @default(true)
  company_json       Json?
  bot_identity_json  Json?
  updated_at         DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  user_id    String?
  action     String
  data_json  Json
  created_at DateTime @default(now())
  user       User?    @relation("UserAuditLogs", fields: [user_id], references: [id])
}

model RolePermission {
  id               String   @id @default(cuid())
  role             UserRole @unique
  permissions_json Json
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
}

model Branch {
  id         String          @id @default(cuid())
  code       String          @unique
  name       String
  address    String
  lat        Float
  lng        Float
  maps_url   String?
  hours_text String
  phone      String?
  is_active  Boolean         @default(true)
  created_at DateTime        @default(now())
  services   ServiceBranch[]
}

model Service {
  id           String          @id @default(cuid())
  code         String          @unique
  name         String
  subtitle     String?
  description  String
  keywords     String?
  price_bob    Int
  duration_min Int?
  image_url    String?
  is_featured  Boolean         @default(false)
  is_active    Boolean         @default(true)
  created_at   DateTime        @default(now())
  branches     ServiceBranch[]

  @@index([is_featured])
}

model ServiceBranch {
  service_id   String
  branch_id    String
  is_available Boolean @default(true)
  branch       Branch  @relation(fields: [branch_id], references: [id])
  service      Service @relation(fields: [service_id], references: [id])

  @@id([service_id, branch_id])
}

model MetaTemplate {
  id                 String                        @id @default(cuid())
  name               String
  meta_template_id   String?
  category           TemplateCategory              @default(UTILITY)
  language           String                        @default("es")
  status             TemplateStatus                @default(DRAFT)
  quality_score      String?
  components_json    Json                          @default("[]")
  body_text          String?
  header_type        String?
  header_content     String?
  footer_text        String?
  buttons_json       Json?
  last_synced_at     DateTime?
  meta_response_json Json?
  rejection_reason   String?
  created_by_user_id String?
  is_deleted         Boolean                       @default(false)
  created_at         DateTime                      @default(now())
  updated_at         DateTime                      @updatedAt
  created_by_user    User?                         @relation("MetaTemplateCreatedBy", fields: [created_by_user_id], references: [id])
  variable_mappings  MetaTemplateVariableMapping[]

  @@unique([name, language])
  @@index([status])
  @@index([is_deleted])
}

model MetaTemplateVariableMapping {
  id            String             @id @default(cuid())
  template_id   String
  var_index     Int
  display_name  String?
  source_type   VariableSourceType
  source_path   String
  default_value String?
  transform     String?
  template      MetaTemplate       @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@unique([template_id, var_index])
}

model AudienceSegment {
  id                 String        @id @default(cuid())
  name               String
  description        String?
  rules_json         Json
  estimated_count    Int           @default(0)
  is_active          Boolean       @default(true)
  created_by_user_id String?
  last_synced_at     DateTime?
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt
  created_by_user    User?         @relation("AudienceCreatedBy", fields: [created_by_user_id], references: [id])
  AudienceTag        AudienceTag[]

  @@index([is_active])
}

model OdooContact {
  id              String   @id @default(cuid())
  odoo_partner_id Int      @unique
  name            String
  phone_e164      String?
  phone_raw       String?
  email           String?
  vat             String?
  is_patient      Boolean  @default(false)
  odoo_patient_id Int?
  tags_json       Json?
  extra_data_json Json?
  last_synced_at  DateTime @default(now())
  created_at      DateTime @default(now())

  @@index([phone_e164])
  @@index([is_patient])
}

model Campaign {
  id                 String            @id @default(cuid())
  name               String
  template_id        String
  audience_filter    Json
  status             CampaignStatus    @default(draft)
  created_by_user_id String?
  scheduled_for      DateTime?
  created_at         DateTime          @default(now())
  created_by_user    User?             @relation("CampaignCreatedBy", fields: [created_by_user_id], references: [id])
  template           Template          @relation(fields: [template_id], references: [id])
  CampaignMessage    CampaignMessage[]

  @@index([status])
}

model TemplateWebhookLog {
  id            String   @id @default(cuid())
  event_type    String
  template_name String?
  template_id   String?
  raw_json      Json
  processed_at  DateTime @default(now())

  @@index([processed_at])
  @@index([template_name])
}

model Prospect {
  id           String   @id @default(cuid())
  wa_id        String   @unique
  phone_e164   String
  display_name String?
  ci_digits    String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([created_at])
}

model AudienceAutomationSetting {
  id              String   @id
  phone_number_id String?
  enabled         Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime

  @@index([phone_number_id])
}

model AudienceTag {
  id              String          @id
  tag_id          String?
  segment_id      String
  phone_number_id String?
  is_default      Boolean         @default(false)
  last_synced_at  DateTime?
  created_at      DateTime        @default(now())
  updated_at      DateTime
  AudienceSegment AudienceSegment @relation(fields: [segment_id], references: [id])
  Tag             Tag?            @relation(fields: [tag_id], references: [id])

  @@unique([tag_id, phone_number_id])
  @@index([phone_number_id])
  @@index([segment_id])
  @@index([tag_id])
}

model CampaignMessage {
  id              String                @id
  campaign_id     String
  conversation_id String?
  wa_id           String
  phone_e164      String
  status          CampaignMessageStatus @default(queued)
  error_json      Json?
  sent_at         DateTime?
  phone_number_id String?
  Campaign        Campaign              @relation(fields: [campaign_id], references: [id])
  Conversation    Conversation?         @relation(fields: [conversation_id], references: [id])

  @@index([campaign_id])
  @@index([phone_number_id])
  @@index([status])
}

model ImportedContact {
  id         String   @id
  phone_e164 String
  name       String?
  city       String?
  tags_json  Json?
  source     String   @default("excel")
  source_ref String?
  created_at DateTime @default(now())
  updated_at DateTime

  @@index([phone_e164])
  @@index([source])
}

model Session {
  id                   String    @id
  wa_id                String
  phone_number_id      String?
  state                String
  data                 Json
  flow_id              String?
  inactivity_notice_at DateTime?
  next_due_at          DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime

  @@unique([wa_id, phone_number_id])
  @@index([flow_id])
  @@index([next_due_at])
  @@index([updated_at])
}

model Template {
  id               String     @id
  name             String     @unique
  language         String
  category         String?
  body_preview     String
  variables_schema Json?
  is_active        Boolean    @default(true)
  created_at       DateTime   @default(now())
  campaigns        Campaign[]
}

enum UserRole {
  admin
  recepcion
  caja
  marketing
  doctor
}

enum ConversationStatus {
  open
  pending
  closed
  assigned
}

enum MessageDirection {
  in
  out
}

enum MessageType {
  text
  interactive
  image
  location
  template
  unknown
  note
  video
  audio
}

enum VerificationMethod {
  phone
  ci
  manual
}

enum TemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PAUSED
  DISABLED
}

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum VariableSourceType {
  odoo
  db
  static
}

enum CampaignStatus {
  draft
  scheduled
  sending
  sent
  failed
}

enum CampaignMessageStatus {
  queued
  sent
  failed
}
