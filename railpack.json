{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "18",
    "python": "3.11"
  },
  "steps": {
    "install": {
      "commands": [
        "...",
        "python -m pip install --upgrade pip",
        "mkdir -p apps/api/.pydeps",
        "python -m pip install --upgrade --target apps/api/.pydeps -r apps/api/requirements-faster-whisper.txt",
        "python apps/api/src/scripts/check_faster_whisper_import.py"
      ]
    }
  },
  "deploy": {
    "startCommand": "npm run start"
  }
}
